# =============================================================================
# 企业微信教务系统 - 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入实际值
# 重要: 不要将包含实际凭证的 .env 文件提交到版本控制！
# =============================================================================

# -----------------------------------------------------------------------------
# 应用基础配置
# -----------------------------------------------------------------------------
# 环境: development | production
ENVIRONMENT=development

# 项目名称
PROJECT_NAME=企业微信教务系统
VERSION=1.0.0

# 调试模式 (生产环境必须设为 false)
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS 允许的来源 (逗号分隔)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------
# 数据库用户名
DB_USER=postgres
# 数据库密码 (生产环境必须设置强密码)
DB_PASSWORD=your_secure_password_here
# 数据库主机
DB_HOST=localhost
# 数据库端口
DB_PORT=5432
# 数据库名称
DB_NAME=education_db
# 数据库连接URL (可选，如设置则优先使用)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/education_db

# -----------------------------------------------------------------------------
# Redis 配置
# -----------------------------------------------------------------------------
# Redis 主机
REDIS_HOST=localhost
# Redis 端口
REDIS_PORT=6379
# Redis 密码 (生产环境必须设置强密码)
REDIS_PASSWORD=
# Redis 数据库编号
REDIS_DB=0

# -----------------------------------------------------------------------------
# JWT 安全配置
# -----------------------------------------------------------------------------
# JWT 密钥 (生产环境必须设置复杂的随机字符串)
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-very-long-secret-key-change-in-production-min-32-chars
# JWT 算法
ALGORITHM=HS256
# Token 过期时间 (分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# 企业微信配置
# -----------------------------------------------------------------------------
# 企业 ID
WEWORK_CORP_ID=your_corp_id
# 应用 Agent ID
WEWORK_AGENT_ID=your_agent_id
# 应用 Secret
WEWORK_SECRET=your_secret
# 服务器验证 Token
WEWORK_TOKEN=your_token
# Encoding AES Key
WEWORK_ENCODING_AES_KEY=your_encoding_aes_key

# -----------------------------------------------------------------------------
# 微信支付配置
# -----------------------------------------------------------------------------
# 商户号
WECHAT_MCH_ID=your_mch_id
# 商户密钥
WECHAT_MCH_KEY=your_mch_key
# 回调通知地址
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/payment/wechat/callback

# -----------------------------------------------------------------------------
# 支付宝配置
# -----------------------------------------------------------------------------
# 应用 ID
ALIPAY_APP_ID=your_app_id
# 私钥 (使用单行格式，去除换行和空格)
ALIPAY_PRIVATE_KEY=your_private_key
# 公钥
ALIPAY_PUBLIC_KEY=your_public_key
# 回调通知地址
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/alipay/callback
# 是否使用沙箱环境 (true | false)
ALIPAY_SANDBOX=false

# -----------------------------------------------------------------------------
# Celery 配置
# -----------------------------------------------------------------------------
# Celery Broker URL
CELERY_BROKER_URL=redis://localhost:6379/1
# Celery Result URL
CELERY_RESULT_URL=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# 文件上传配置
# -----------------------------------------------------------------------------
# 上传目录
UPLOAD_DIR=./uploads
# 最大文件大小 (字节)
MAX_FILE_SIZE=10485760

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
# 日志级别: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
